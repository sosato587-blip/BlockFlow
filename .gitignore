__pycache__/
.DS_Store
.env
node_modules/
.next/
venv/
.venv/

# Runtime data (local only)
run_history.db
job_history.json
output/
prompt_writer_settings.json

# Flow data (tracked for multi-machine sync)
# flows/*.flow.json

# Dev artifacts — ignore lowercase variants only (ARCHITECTURE.md is tracked)
/architecture.md
frontend/architecture.md
/issues.md
frontend/issues.md
logs.txt

# IDE / Claude Code launch configs.
# Convention (Claude Code docs):
#   .claude/settings.json       → tracked, shared with team (Pre-Task Charter
#                                  hooks etc. live here)
#   .claude/settings.local.json → personal overrides, NOT tracked
#   .claude/launch.json         → IDE specific, NOT tracked
# Everything else under .claude/ stays ignored unless explicitly negated.
.claude/*
!.claude/settings.json
!.claude/hooks/
data/

# Auto-generated block registry (regenerated by predev / prebuild hooks).
# Tracking these causes `git pull` conflicts on every dev restart because
# the hook rewrites them before the pull can complete.
frontend/src/components/pipeline/custom_blocks/generated/
