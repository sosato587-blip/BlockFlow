# ============================================================
# .gitattributes — line ending normalization for cross-platform dev
# ============================================================
# Auto-detect text files; commit as LF, checkout per-OS native
* text=auto

# Explicit text formats — always LF in repo, OS-native on checkout
*.py        text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.toml      text eol=lf
*.css       text eol=lf
*.html      text eol=lf
*.sh        text eol=lf
*.gitignore text eol=lf

# Windows-only scripts — keep CRLF (PowerShell prefers it)
*.ps1       text eol=crlf
*.bat       text eol=crlf
*.cmd       text eol=crlf

# Binary files — never auto-convert
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.webp      binary
*.ico       binary
*.mp4       binary
*.webm      binary
*.mov       binary
*.safetensors binary
*.pth       binary
*.ckpt      binary
*.bin       binary
*.gguf      binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.otf       binary
*.zip       binary
*.tar.gz    binary
